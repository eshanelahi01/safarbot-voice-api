APP_NAME=SafarBot AI Service
APP_VERSION=2.0.0
INTENT_MODEL=eshanelahi0/safarbot-intent-v5
SLOT_MODEL=eshanelahi0/safarbot-slot-v5
HF_TOKEN=
BACKEND_URL=https://safarbot-91nr.onrender.com
USE_GPU=0
MODEL_LOAD_ON_STARTUP=0
ENABLE_RULE_BASED_NLU_FALLBACK=1
INTENT_MIN_CONF=0.50
SLOT_MIN_CONF=0.65
SESSION_TTL_SECONDS=3600
SESSION_MAX_SESSIONS=10000
REQUEST_TIMEOUT_SECONDS=12
BACKEND_RETRY_ATTEMPTS=2
BACKEND_RETRY_BACKOFF_SECONDS=0.75
STT_MODEL_SIZE=small
STT_COMPUTE_TYPE=int8
TTS_AZURE_ENDPOINT=
TTS_AZURE_KEY=
TTS_AZURE_VOICE_EN=en-US-JennyNeural
TTS_AZURE_VOICE_UR=ur-PK-UzmaNeural
TTS_GTTS_ENABLED=1
TTS_GTTS_TLD=com
TTS_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3
